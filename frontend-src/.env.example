# Red Shrimp Lab — Frontend Environment Variables
# Copy to .env.local for development

# Backend API base (without trailing slash)
# Dev: leave empty to use Vite proxy (localhost:3001)
# Prod: set to your ECS public URL e.g. https://your-domain.com/api
VITE_API_BASE=

# WebSocket server URL
# Dev: leave empty (uses Vite proxy)
# Prod: https://your-domain.com
VITE_WS_URL=

# Optional dev-only auto login. Leave empty in production.
VITE_AUTO_LOGIN_IDENTITY=
VITE_AUTO_LOGIN_NAME=

# Web Push VAPID public key (must match backend VAPID_PUBLIC_KEY)
VITE_VAPID_PUBLIC_KEY=
