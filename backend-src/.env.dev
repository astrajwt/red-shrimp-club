# 本地开发用最小配置（复制为 .env 使用）
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# 生成命令: openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_RANDOM_SECRET

# 本地 PostgreSQL（setup.sh 创建的默认值）
DB_HOST=localhost
DB_PORT=5432
DB_NAME=redshrimp
DB_USER=postgres
DB_PASSWORD=

# 本地文件上传目录
UPLOADS_DIR=/tmp/redshrimp-uploads

# 你的 Anthropic API Key（必填，agent 功能需要）
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# 可选（先不填也能启动）
MOONSHOT_API_KEY=
OPENAI_API_KEY=

# Obsidian 仓库路径（本地已有）
OBSIDIAN_ROOT=/home/jwt/JwtVault
