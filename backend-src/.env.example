# Red Shrimp Lab — Environment Variables
# Copy to .env and fill in real values

# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# JWT (generate with: openssl rand -hex 64)
JWT_SECRET=replace_with_64_char_random_hex
LOCAL_AUTH_BYPASS=false

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=redshrimp
DB_USER=postgres
DB_PASSWORD=your_db_password

# File uploads
UPLOADS_DIR=/var/redshrimp/uploads

# LLM Provider API Keys
ANTHROPIC_API_KEY=sk-ant-...
MOONSHOT_API_KEY=sk-...
OPENAI_API_KEY=sk-...

# Obsidian Vault Path
OBSIDIAN_ROOT=/path/to/your/vault

# Web Push (VAPID keys — generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:admin@redshrimp.local

# Feishu Relay (Akara relay bot)
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx
FEISHU_VERIFICATION_TOKEN=xxx
FEISHU_WEBHOOK_BASE_URL=https://your-public-host.example.com
