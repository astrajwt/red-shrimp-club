# Red Shrimp Lab — Environment Variables
# Copy to .env and fill in real values

# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# JWT (generate with: openssl rand -hex 64)
JWT_SECRET=replace_with_64_char_random_hex

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=redshrimp
DB_USER=postgres
DB_PASSWORD=your_db_password

# File uploads
UPLOADS_DIR=/var/redshrimp/uploads

# LLM Provider API Keys
ANTHROPIC_API_KEY=sk-ant-...
MOONSHOT_API_KEY=sk-...
OPENAI_API_KEY=sk-...

# Obsidian Vault Path
OBSIDIAN_ROOT=/home/jwt/JwtVault/slock-clone
